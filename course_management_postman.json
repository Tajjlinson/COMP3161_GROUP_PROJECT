{
  "info": {
    "name": "COMP3161 - Course Management & Enrollment (Person 2)",
    "description": "Postman collection for Course Management & Enrollment API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Create Course (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_name\": \"Database Systems\",\n  \"created_by_admin\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/courses",
          "host": ["{{base_url}}"],
          "path": ["courses"]
        },
        "description": "Admin creates a new course. Requires course_name and created_by_admin."
      },
      "response": [
        {
          "name": "201 Created",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"message\": \"Course created\",\n  \"course_id\": 1\n}"
        }
      ]
    },
    {
      "name": "2. Get All Courses",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/courses",
          "host": ["{{base_url}}"],
          "path": ["courses"]
        },
        "description": "Retrieve all courses in the system."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "[\n  {\n    \"course_id\": 1,\n    \"course_name\": \"Database Systems\",\n    \"created_by_admin\": 1\n  },\n  {\n    \"course_id\": 2,\n    \"course_name\": \"Object-Oriented Design\",\n    \"created_by_admin\": 1\n  }\n]"
        }
      ]
    },
    {
      "name": "3. Register Student in Course",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"student_id\": 100\n}"
        },
        "url": {
          "raw": "{{base_url}}/courses/1/register",
          "host": ["{{base_url}}"],
          "path": ["courses", "1", "register"]
        },
        "description": "Register a student into a specific course by course_id."
      },
      "response": [
        {
          "name": "201 Created",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"message\": \"Student registered successfully\",\n  \"enrollment_id\": 1\n}"
        },
        {
          "name": "409 Already Enrolled",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"Student already enrolled in this course\"\n}"
        },
        {
          "name": "404 Course Not Found",
          "status": "Not Found",
          "code": 404,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"Course not found\"\n}"
        }
      ]
    },
    {
      "name": "4. Get Courses for Student",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/courses/student/100",
          "host": ["{{base_url}}"],
          "path": ["courses", "student", "100"]
        },
        "description": "Retrieve all courses that a specific student is enrolled in."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "[\n  {\n    \"course_id\": 1,\n    \"course_name\": \"Database Systems\",\n    \"created_by_admin\": 1\n  },\n  {\n    \"course_id\": 2,\n    \"course_name\": \"Object-Oriented Design\",\n    \"created_by_admin\": 1\n  }\n]"
        }
      ]
    },
    {
      "name": "5. Get Courses for Lecturer",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/courses/lecturer/10",
          "host": ["{{base_url}}"],
          "path": ["courses", "lecturer", "10"]
        },
        "description": "Retrieve all courses taught by a specific lecturer."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "[\n  {\n    \"course_id\": 1,\n    \"course_name\": \"Database Systems\",\n    \"created_by_admin\": 1\n  },\n  {\n    \"course_id\": 3,\n    \"course_name\": \"Computer Systems Organization\",\n    \"created_by_admin\": 2\n  }\n]"
        }
      ]
    }
  ]
}