              "}\r",
              "\r",
              "pm.test(\"Got access_token\", () => {\r",
              "  if (pm.response.code === 200) {\r",
              "    pm.expect(json).to.have.property(\"access_token\");\r",
              "    pm.expect(json.access_token).to.be.a(\"string\").and.not.be.empty;\r",
